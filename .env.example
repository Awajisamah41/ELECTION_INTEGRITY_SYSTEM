# ============================================================
# ELECTION INTEGRITY MANAGEMENT SYSTEM - Environment Variables
# ============================================================
# Copy this file to .env and fill in your values

# Server
PORT=5000
NODE_ENV=development

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=election_db
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_SSL=false

# JWT Authentication
JWT_SECRET=your_very_long_super_secret_jwt_key_here_min_32_chars
JWT_EXPIRES_IN=8h

# Central Electoral Commission Server (for result uploads)
CENTRAL_SERVER_URL=https://results.iec.gov.ng/api
CENTRAL_SERVER_API_KEY=your_central_server_api_key

# File Upload (for result sheets and asset declarations)
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
